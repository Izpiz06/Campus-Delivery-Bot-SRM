generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model hostels {
  hostel_id   Int      @id @default(autoincrement())
  hostel_name String   @unique @db.VarChar(50)
  hostel_type Boolean?
  users       users[]
}

model users {
  sno                 Int                   @default(autoincrement())
  regno               String                @id @db.VarChar(20)
  name                String?               @db.VarChar(50)
  email               String?               @unique(map: "users_email_unique") @db.VarChar(50)
  phone               String?               @db.VarChar(15)
  password_hash       String                @db.VarChar(255)
  role                String                @default("user") @db.VarChar(10)
  hostel_id           Int?
  is_verified         Boolean?              @default(false)
  email_verifications email_verifications[]
  hostels             hostels?              @relation(fields: [hostel_id], references: [hostel_id], onUpdate: NoAction, map: "fk_users_hostel")
}

model email_verifications {
  id              Int       @id @default(autoincrement())
  regno           String?   @db.VarChar(20)
  otp_code_email  String    @db.VarChar(6)
  expires_at      DateTime  @db.Timestamp(6)
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  otp_code_mobile String    @db.VarChar(6)
  users           users?    @relation(fields: [regno], references: [regno], onDelete: Cascade, onUpdate: NoAction)
}
